# Notion API 配置
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion 三資料庫架構 (Zettelkasten 功能)
# 書籍資料庫 ID (可選，如果和 NOTION_DATABASE_ID 不同)
NOTION_BOOKS_DATABASE_ID=your_books_database_id_here
# Kobo 畫線匯出資料庫 ID (預設使用 NOTION_DATABASE_ID)
NOTION_HIGHLIGHTS_DATABASE_ID=your_kobo_highlights_database_id_here
# 卡片資料庫 ID (必須先在 Notion 建立)
NOTION_ZETTELKASTEN_DATABASE_ID=your_zettelkasten_database_id_here

# Kobo 配置 (可選)
KOBO_DB_PATH=KoboReader.sqlite

# 性能配置 (可選)
MAX_WORKERS=5
BATCH_SIZE=90
LOG_LEVEL=INFO

# Dry-run 模式 (true/false)：讀取 Kobo 與查詢 Notion 照常，但所有寫入
# (建立頁面/上傳劃線/更新屬性/封面) 只印 log 不執行；卡片流程整個跳過。
# 用於驗證 infrastructure 層改動 (見 CLAUDE.md Engineering Standards §2)。
DRY_RUN=false

# ==========================================
# Zettelkasten 卡片筆記功能設定
# ==========================================

# 啟用/停用 Zettelkasten 卡片生成 (true/false)
ENABLE_ZETTELKASTEN_CARDS=false

# 最多生成卡片數量 (預設: 16)
ZETTELKASTEN_MAX_CARDS=16

# 最低劃線數量門檻 (劃線數量低於此值不產生卡片)
ZETTELKASTEN_MIN_HIGHLIGHTS=10

# 產生的卡片本地留存目錄 (供上傳失敗時續傳，預設: cards_output)
ZETTELKASTEN_CARDS_OUTPUT_DIR=cards_output

# 卡片盒 Tags 固定分類清單 (逗號分隔)；LLM 只能從此清單挑，歸不進去留空。
# 留空則用內建預設 (見 src/config/settings.py DEFAULT_TAG_CATEGORIES)。
# 程式啟動時會自動把缺少的選項補進卡片盒 Tags 欄位。
ZETTELKASTEN_TAG_CATEGORIES=💞心理學,🧠學習技巧,💼商務,🧘‍♂️人生觀點,🧩邏輯思考,🔬哲學科學,💻軟體工程,📈行銷,📋專案管理,💰理財投資

# ==========================================
# Ollama LLM 設定 (本地生成卡片初稿)
# ==========================================
# 需要先安裝 Ollama: https://ollama.com
# 然後執行: ollama pull gemma3:4b

# Ollama API URL (預設: http://localhost:11434/api/generate)
OLLAMA_API_URL=http://localhost:11434/api/generate

# Ollama 模型名稱 (建議: gemma3:4b 或 gemma3:12b; thinking 模型如 gemma4:e4b 也可)
OLLAMA_MODEL=gemma3:4b

# 單張卡請求 timeout (秒)，冷啟動或 thinking 模型建議 300+
OLLAMA_TIMEOUT_SECONDS=300

# 單張卡 num_predict 上限，thinking 模型需較大空間 (建議 2000+)
OLLAMA_NUM_PREDICT=2000

# 模型駐留時間，避免批次中途被卸載
OLLAMA_KEEP_ALIVE=30m

# 批次請求 (一次生成所有卡片) 的 timeout (秒)
OLLAMA_BATCH_TIMEOUT_SECONDS=600

# 批次請求的 num_predict (-1 = 無上限，由 context 決定)
OLLAMA_BATCH_NUM_PREDICT=-1

# 批次請求的 context 視窗大小；需 <= 模型實際支援上限
OLLAMA_BATCH_NUM_CTX=16384

# ==========================================
# Gemini API 設定 (審核優化卡片品質)
# ==========================================
# 需要先取得 API Key: https://makersuite.google.com/app/apikey

# Gemini API Key (留空則跳過審核)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 模型 (預設: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# 品質評分門檻 (低於此分數的卡片會被 Gemini 重寫，預設: 6)
GEMINI_REVIEW_THRESHOLD=6