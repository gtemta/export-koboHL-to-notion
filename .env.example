# Notion API 配置
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Notion 三資料庫架構 (Zettelkasten 功能)
# 書籍資料庫 ID (可選，如果和 NOTION_DATABASE_ID 不同)
NOTION_BOOKS_DATABASE_ID=your_books_database_id_here
# Kobo 畫線匯出資料庫 ID (預設使用 NOTION_DATABASE_ID)
NOTION_HIGHLIGHTS_DATABASE_ID=your_kobo_highlights_database_id_here
# 卡片資料庫 ID (必須先在 Notion 建立)
NOTION_ZETTELKASTEN_DATABASE_ID=your_zettelkasten_database_id_here

# Kobo 配置 (可選)
KOBO_DB_PATH=KoboReader.sqlite

# 性能配置 (可選)
MAX_WORKERS=5
BATCH_SIZE=90
LOG_LEVEL=INFO

# ==========================================
# Zettelkasten 卡片筆記功能設定
# ==========================================

# 啟用/停用 Zettelkasten 卡片生成 (true/false)
ENABLE_ZETTELKASTEN_CARDS=false

# 最多生成卡片數量 (預設: 16)
ZETTELKASTEN_MAX_CARDS=16

# 最低劃線數量門檻 (劃線數量低於此值不產生卡片)
ZETTELKASTEN_MIN_HIGHLIGHTS=10

# ==========================================
# Ollama LLM 設定 (本地生成卡片初稿)
# ==========================================
# 需要先安裝 Ollama: https://ollama.com
# 然後執行: ollama pull gemma3:4b

# Ollama API URL (預設: http://localhost:11434/api/generate)
OLLAMA_API_URL=http://localhost:11434/api/generate

# Ollama 模型名稱 (建議: gemma3:4b 或 gemma3:12b)
OLLAMA_MODEL=gemma3:4b

# ==========================================
# Gemini API 設定 (審核優化卡片品質)
# ==========================================
# 需要先取得 API Key: https://makersuite.google.com/app/apikey

# Gemini API Key (留空則跳過審核)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini 模型 (預設: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# 品質評分門檻 (低於此分數的卡片會被 Gemini 重寫，預設: 6)
GEMINI_REVIEW_THRESHOLD=6